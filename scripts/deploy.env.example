# grok2api 部署脚本环境变量样例
# 用法：复制为同目录 deploy.env 并填入你的真实值。
# 脚本默认读取：scripts/deploy.env

# 必填：远程登录地址（格式：user@host）
# 作用：ssh/rsync 连接远程服务器。
REMOTE_HOST="root@example.com"

# 必填：远程 Nginx 站点配置文件路径
# 作用：部署成功后自动把 upstream 端口从 8000/8001 切换到新容器。
REMOTE_NGINX_SITE="/etc/nginx/sites-enabled/example.conf"

# 可选：远程项目目录（默认 /opt/grok2api）
# 作用：同步代码、docker build 的工作目录。
REMOTE_APP_DIR="/opt/grok2api"

# 可选：远程持久化根目录（默认 /opt/grok2api_persist）
# 作用：按端口保存 data/logs/runtime.env，支持蓝绿切换保留数据。
REMOTE_PERSIST_ROOT="/opt/grok2api_persist"

# 可选：镜像名（默认 grok2api:latest）
# 作用：docker build -t 与 docker run 使用的镜像标签。
IMAGE_NAME="grok2api:latest"

# 可选：容器名前缀（默认 grok2api）
# 作用：容器会命名为 <前缀>-8000 或 <前缀>-8001。
CONTAINER_PREFIX="grok2api"

# 可选：本地 ssh 额外参数（默认空）
# 作用：统一给 ssh/rsync 使用，例如指定端口、密钥、跳板机。
# 示例：-p 22 -i ~/.ssh/id_rsa
SSH_OPTS=""

# 可选：本地项目根目录（默认脚本上级目录）
# 作用：指定实际需要同步/构建的仓库目录；通常无需修改。
# PROJECT_DIR="/path/to/grok2api"
